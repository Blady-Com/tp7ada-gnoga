   function GetFont (Font : Word) return DescFont is
   begin
      case Font is
         when DefaultFont => -- double line, no error, 223 characters
            return LITTChar;
         when TriplexFont => -- triple line, no error, 223 characters
            return TRIPChar;
         when SmallFont => -- small double line, no error, 223 characters
            return LITTChar;
         when SansSerifFont => -- double line, 15 errors, 254 characters
            return SANSChar;
         when GothicFont => -- gothic triple line, no error, 223 characters
            return GOTHChar;
         when ScriptFont => -- cursive, no error, 223 characters
            return SCRIChar;
         when SimplexFont => -- simple line, no error, 223 characters
            return SIMPChar;
         when TriplexScriptFont => -- triple line italic, no error, 223 characters
            return TSCRChar;
         when ComplexFont => -- double line, no error, 223 characters
            return LCOMChar;
         when EuropeanFont => -- round letters, no error, 223 characters
            return EUROChar;
         when BoldFont => -- big double line, no error, 224 characters
            return BOLDChar;
         when others =>
            IntGraphResult := grError;
            return null;
      end case;
   end GetFont;
   function To_CodePage437 (Ch : Byte) return Byte is
   begin
      case Ch is
         when 0 .. 31 =>
            return Ch; -- Control characters
         when 32 .. 127 =>
            return Ch; -- ISO 646 graphic characters
         when 128 .. 159 =>
            return Ch - 128 + 224; -- Greek characters
         when 160 .. 255 =>
            return Latin1_To_CodePage437 (Ch); -- Other graphic characters
      end case;
   end To_CodePage437;
end FontCHR;
